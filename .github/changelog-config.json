{
  "categories": [
    {
      "title": "## 🚀 Features",
      "labels": ["feature", "enhancement"]
    },
    {
      "title": "## 🐛 Bug Fixes",
      "labels": ["bug", "fix"]
    },
    {
      "title": "## 🧪 Tests",
      "labels": ["test", "testing"]
    },
    {
      "title": "## 📚 Documentation",
      "labels": ["docs", "documentation"]
    },
    {
      "title": "## 🔧 Maintenance",
      "labels": ["chore", "maintenance", "refactor"]
    },
    {
      "title": "## 📦 Dependencies",
      "labels": ["dependencies"]
    },
    {
      "title": "## 🛡️ Security",
      "labels": ["security"]
    }
  ],
  "ignore_labels": [
    "ignore"
  ],
  "sort": "ASC",
  "template": "${{CHANGELOG}}\n\n## 📊 Statistics\n\n- **Commits**: ${{COMMITS}}\n- **Contributors**: ${{CONTRIBUTORS}}\n- **Changed Files**: ${{CHANGED_FILES}}\n",
  "pr_template": "- ${{TITLE}} (#{{NUMBER}}) - @{{AUTHOR}}",
  "empty_template": "- No changes",
  "label_extractor": [
    {
      "pattern": "^(build|chore|ci|docs|feat|fix|perf|refactor|revert|style|test){1}(\([\w\-\.]+\))?(!)?: ([\w ])+([\s\S]*)",
      "target": "$1"
    }
  ],
  "transformers": [
    {
      "pattern": "^(.+)\\s*-\\s+@(.+)$",
      "target": "$1"
    }
  ],
  "max_tags_to_fetch": 200,
  "max_pull_requests": 200,
  "max_back_track_time_days": 365
}
