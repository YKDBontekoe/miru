#!/bin/bash
# Pre-commit hook aligned with CI lint steps

set -u

echo "Running pre-commit checks..."
EXIT_CODE=0
ROOT_DIR=$(git rev-parse --show-toplevel)

if [ -d "$ROOT_DIR/backend" ]; then
  echo "Checking backend (CI parity: ruff + format + ty)..."
  cd "$ROOT_DIR/backend"

  if command -v uv >/dev/null 2>&1; then
    if ! uv run ruff check .; then
      EXIT_CODE=1
    fi
    if ! uv run ruff format --check .; then
      EXIT_CODE=1
    fi
    if ! uv run ty check .; then
      EXIT_CODE=1
    fi
  else
    if [ -f ".venv/bin/ruff" ] && [ -f ".venv/bin/ty" ]; then
      if ! .venv/bin/ruff check .; then
        EXIT_CODE=1
      fi
      if ! .venv/bin/ruff format --check .; then
        EXIT_CODE=1
      fi
      if ! .venv/bin/ty check .; then
        EXIT_CODE=1
      fi
    else
      echo "Backend tooling missing. Install uv or backend/.venv first."
      EXIT_CODE=1
    fi
  fi

  cd "$ROOT_DIR"
fi

if [ -d "$ROOT_DIR/frontend" ]; then
  echo "Checking frontend (CI parity: type-check then lint)..."
  cd "$ROOT_DIR/frontend"

  if [ ! -d "node_modules" ]; then
    npm install --legacy-peer-deps
  fi

  if ! npm run type-check; then
    EXIT_CODE=1
  fi
  if ! npm run lint; then
    EXIT_CODE=1
  fi

  cd "$ROOT_DIR"
fi

if [ "$EXIT_CODE" -ne 0 ]; then
  echo "Pre-commit checks failed."
  exit 1
fi

echo "All pre-commit checks passed!"
exit 0
