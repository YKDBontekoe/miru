#!/bin/bash
# Pre-commit hook aligned with CI lint steps

set -u

echo "Running pre-commit checks..."
EXIT_CODE=0
ROOT_DIR=$(git rev-parse --show-toplevel)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMRD)

has_staged_prefix() {
  local prefix="$1"
  printf '%s\n' "$STAGED_FILES" | grep -q "^${prefix}/"
}

RUN_BACKEND=false
RUN_FRONTEND=false

if has_staged_prefix "backend"; then
  RUN_BACKEND=true
fi
if has_staged_prefix "frontend"; then
  RUN_FRONTEND=true
fi

if [ "$RUN_BACKEND" = false ] && [ "$RUN_FRONTEND" = false ]; then
  echo "No staged backend/frontend changes detected. Skipping language-specific checks."
  exit 0
fi

if [ "$RUN_BACKEND" = true ] && [ -d "$ROOT_DIR/backend" ]; then
  echo "Checking backend (CI parity: ruff + format + ty + tests)..."
  cd "$ROOT_DIR/backend"

  if command -v uv >/dev/null 2>&1; then
    if ! uv run ruff check .; then
      EXIT_CODE=1
    fi
    if ! uv run ruff format --check .; then
      EXIT_CODE=1
    fi
    if ! uv run ty check .; then
      EXIT_CODE=1
    fi
    if [ "${SKIP_BACKEND_TESTS:-false}" = "true" ]; then
      echo "Skipping backend tests because SKIP_BACKEND_TESTS=true"
    else
      if ! uv run pytest -q; then
        EXIT_CODE=1
      fi
    fi
  else
    if [ -f ".venv/bin/ruff" ] && [ -f ".venv/bin/ty" ]; then
      if ! .venv/bin/ruff check .; then
        EXIT_CODE=1
      fi
      if ! .venv/bin/ruff format --check .; then
        EXIT_CODE=1
      fi
      if ! .venv/bin/ty check .; then
        EXIT_CODE=1
      fi
      if [ "${SKIP_BACKEND_TESTS:-false}" = "true" ]; then
        echo "Skipping backend tests because SKIP_BACKEND_TESTS=true"
      else
        if ! .venv/bin/pytest -q; then
          EXIT_CODE=1
        fi
      fi
    else
      echo "Backend tooling missing. Install uv or backend/.venv first."
      EXIT_CODE=1
    fi
  fi

  cd "$ROOT_DIR"
elif [ "$RUN_BACKEND" = true ]; then
  echo "Backend directory not found; cannot run backend checks."
  EXIT_CODE=1
fi

if [ "$RUN_FRONTEND" = true ] && [ -d "$ROOT_DIR/frontend" ]; then
  echo "Checking frontend (CI parity: type-check, lint, tests)..."
  cd "$ROOT_DIR/frontend"

  if [ ! -d "node_modules" ]; then
    if ! npm install --legacy-peer-deps; then
      echo "npm install failed. Aborting pre-commit checks."
      exit 1
    fi
  fi

  if ! npm run type-check; then
    EXIT_CODE=1
  fi
  if ! npm run lint; then
    EXIT_CODE=1
  fi
  if [ "${SKIP_FRONTEND_TESTS:-false}" = "true" ]; then
    echo "Skipping frontend tests because SKIP_FRONTEND_TESTS=true"
  else
    if ! npm test -- --runInBand --watchAll=false; then
      EXIT_CODE=1
    fi
  fi

  cd "$ROOT_DIR"
elif [ "$RUN_FRONTEND" = true ]; then
  echo "Frontend directory not found; cannot run frontend checks."
  EXIT_CODE=1
fi

if [ "$EXIT_CODE" -ne 0 ]; then
  echo "Pre-commit checks failed."
  exit 1
fi

echo "All pre-commit checks passed!"
exit 0
