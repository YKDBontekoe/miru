{
  "name": "frontend",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo.*|@expo/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|nativewind|react-native-reanimated|@supabase/.*|axios)"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@supabase/supabase-js": "^2.99.3",
    "axios": "^1.13.6",
    "babel-preset-expo": "^55.0.12",
    "expo": "~55.0.8",
    "expo-build-properties": "~0.13.2",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-linking": "~55.0.8",
    "expo-localization": "^55.0.9",
    "expo-router": "~55.0.7",
    "expo-haptics": "~14.0.1",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "i18next": "^25.10.3",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.6.0",
    "react-native": "0.83.2",
    "react-native-markdown-display": "^7.0.2",
    "react-native-mmkv": "^4.3.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.7.2",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.12"
  },
  "overrides": {
    "markdown-it": "^14.1.1",
    "http-proxy-agent": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
