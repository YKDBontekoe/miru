OPENROUTER_API_KEY=your_openrouter_api_key_here
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# Direct PostgreSQL connection string for migrations (required for Alembic)
# Get this from Supabase Dashboard > Settings > Database > Connection string > URI (direct connection)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=your_supabase_direct_connection_string

# Neo4j Graph Database configuration
# Get these from Neo4j Aura (cloud) or your Neo4j instance
NEO4J_URI=bolt://xxxxx.databases.neo4j.io:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Optional overrides (defaults shown)
# EMBEDDING_MODEL=openai/text-embedding-3-small
# DEFAULT_CHAT_MODEL=anthropic/claude-3.5-sonnet
