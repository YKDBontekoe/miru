OPENROUTER_API_KEY=your_openrouter_api_key_here

# ---------------------------------------------------------------------------
# Supabase configuration
# ---------------------------------------------------------------------------

# Project URL — from Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=your_supabase_project_url

# Anon key — safe for client-side; used for RLS-protected queries
# From Supabase Dashboard > Settings > API > Project API keys > anon / public
SUPABASE_KEY=your_supabase_anon_key

# Service role key — NEVER expose to clients; used by the backend ONLY for
# admin operations (e.g. creating sessions after passkey authentication).
# From Supabase Dashboard > Settings > API > Project API keys > service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT secret — used to validate Supabase-issued JWTs on the backend.
# From Supabase Dashboard > Settings > API > JWT Settings > JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Direct PostgreSQL connection string for migrations (required for Alembic)
# From Supabase Dashboard > Settings > Database > Connection string > URI (direct connection)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=your_supabase_direct_connection_string

# ---------------------------------------------------------------------------
# Neo4j Graph Database
# ---------------------------------------------------------------------------

NEO4J_URI=bolt://xxxxx.databases.neo4j.io:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ---------------------------------------------------------------------------
# WebAuthn / Passkey configuration
# ---------------------------------------------------------------------------

# Must match your app domain exactly (no scheme, no port for standard ports).
# Use "localhost" for local development.
WEBAUTHN_RP_ID=localhost

# Human-readable name shown in the passkey prompt on the user's device.
WEBAUTHN_RP_NAME=Miru

# Comma-separated list of allowed origins for passkey ceremonies.
# Must match the origin(s) where your Flutter web app / API is hosted.
WEBAUTHN_EXPECTED_ORIGIN=http://localhost

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Comma-separated allowed origins. Use "*" only in development.
CORS_ALLOWED_ORIGINS=*

# ---------------------------------------------------------------------------
# Optional model overrides (defaults shown)
# ---------------------------------------------------------------------------

# EMBEDDING_MODEL=openai/text-embedding-3-small
# DEFAULT_CHAT_MODEL=anthropic/claude-3.5-sonnet
