          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"is_positive\": true}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/messages/{{message_id}}/feedback",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "messages",
            "{{message_id}}",
            "feedback"
          ]
        }
      },
      "response": []
    }
  ]
