{
  "info": {
    "_postman_id": "11111111-1111-1111-1111-000000000008",
    "name": "Logic Integration Tests",
    "description": "Integration tests for business logic, requiring authentication.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Create Agent",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201 or 200\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set(\"agentId\", jsonData.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Agent\",\n  \"personality\": \"Friendly and helpful\",\n  \"description\": \"A test agent for CI\",\n  \"goals\": [\"Help with testing\"],\n  \"capabilities\": [],\n  \"integrations\": []\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/agents",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "agents"]
        }
      }
    },
    {
      "name": "Get Agents",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Body is an array\", function () {",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/agents",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "agents"]
        }
      }
    },
    {
      "name": "Create Chat Room",
      "event": [
        {
          "listen": "test",
          "script": {
