{
  "info": {
    "_postman_id": "00000000-0000-0000-0000-000000000000",
    "name": "00_Setup_Auth",
    "description": "Sets up authentication by logging into Supabase and storing the token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login to Supabase",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const supabaseUrl = pm.environment.get(\"supabaseUrl\");",
              "const supabaseKey = pm.environment.get(\"supabaseKey\");",
              "const testEmail = pm.environment.get(\"testEmail\");",
              "const testPassword = pm.environment.get(\"testPassword\");",
              "",
              "// Seed the user first by attempting a signup",
              "const signupRequest = {",
              "  url: `${supabaseUrl}/auth/v1/signup`,",
              "  method: 'POST',",
              "  header: {",
              "    'apikey': supabaseKey,",
              "    'Content-Type': 'application/json'",
              "  },",
              "  body: {",
              "    mode: 'raw',",
              "    raw: JSON.stringify({ email: testEmail, password: testPassword })",
              "  }",
              "};",
              "",
              "pm.sendRequest(signupRequest, function (err, res) {",
              "    if (err) {",
              "        console.log(\"Signup request failed entirely:\", err);",
              "    } else {",
              "        console.log(\"Signup attempted. Status:\", res.code);",
              "        // If code is 400 with 'User already registered', that is fine.",
              "        // If code is 200, user is created.",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Extract and set bearerToken\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('access_token');",
              "    pm.environment.set(\"bearerToken\", jsonData.access_token);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "apikey",
            "value": "{{supabaseKey}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"{{testEmail}}\", \"password\": \"{{testPassword}}\"}"
        },
        "url": {
          "raw": "{{supabaseUrl}}/auth/v1/token?grant_type=password",
          "host": ["{{supabaseUrl}}"],
          "path": ["auth", "v1", "token"],
          "query": [
            {
              "key": "grant_type",
              "value": "password"
            }
          ]
        }
      }
    }
  ]
}
