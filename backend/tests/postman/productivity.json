  "info": {
    "_postman_id": "11111111-1111-1111-1111-000000000005",
    "name": "Productivity Endpoints",
    "description": "Integration tests for productivity endpoints. Tests unauthenticated (401) and authenticated CRUD scenarios for tasks, notes, and calendar events.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Prefer an injected authToken (real Supabase session token) when available.",
          "var existingAuthToken = pm.environment.get('authToken') || pm.variables.get('authToken');",
          "if (typeof existingAuthToken === 'string' && existingAuthToken.trim()) {",
          "    return;",
          "}",
          "",
          "// Fallback: generate a Supabase-compatible HS256 JWT for authenticated tests.",
          "// Requires the `jwtSecret` environment variable to be set via --env-var jwtSecret=<SUPABASE_JWT_SECRET>.",
          "var CryptoJS = require('crypto-js');",
          "var rawSecret = pm.environment.get('jwtSecret') || pm.variables.get('jwtSecret') || '';",
          "var secret = (typeof rawSecret === 'string' ? rawSecret : String(rawSecret)).trim();",
          "",
          "pm.test(\"jwtSecret is present\", function() {",
          "    pm.expect(secret).to.be.a('string').and.not.empty;",
          "});",
          "",
          "if (!secret) {",
          "    pm.environment.unset('authToken');",
          "    return;",
          "}",
          "",
          "var userId = pm.environment.get('testUserId') || '11111111-1111-1111-1111-111111111111';",
          "var now = Math.floor(Date.now() / 1000);",
          "",
          "function base64UrlEncode(str) {",
          "    return CryptoJS.enc.Base64.stringify(CryptoJS.enc.Utf8.parse(str))",
          "        .replace(/=/g, '').replace(/\\+/g, '-').replace(/\\//g, '_');",
          "}",
          "",
          "var header  = base64UrlEncode(JSON.stringify({ alg: 'HS256', typ: 'JWT' }));",
          "var payload = base64UrlEncode(JSON.stringify({",
          "    sub: userId,",
          "    role: 'authenticated',",
          "    iss: 'supabase',",
          "    aud: 'authenticated',",
          "    iat: now,",
          "    exp: now + 3600",
          "}));",
          "",
          "var signingInput = header + '.' + payload;",
          "var signature = CryptoJS.HmacSHA256(signingInput, secret);",
          "var signatureB64 = CryptoJS.enc.Base64.stringify(signature)",
          "    .replace(/=/g, '').replace(/\\+/g, '-').replace(/\\//g, '_');",
          "",
          "pm.environment.set('authToken', signingInput + '.' + signatureB64);"
        ],
        "type": "text/javascript"
      }
    }
  ],
