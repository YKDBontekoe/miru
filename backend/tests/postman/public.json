{
  "info": {
    "_postman_id": "11111111-1111-1111-1111-000000000001",
    "name": "Public Endpoints",
    "description": "Integration tests for public (unauthenticated) endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is valid JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "pm.test(\"Status field is 'ok'\", function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('status');",
              "    pm.expect(json.status).to.eql('ok');",
              "});",
              "",
              "pm.test(\"Response time is below 2000ms\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "OpenAPI Spec",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is valid JSON\", function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "pm.test(\"Schema contains openapi version field\", function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('openapi');",
              "});",
              "",
              "pm.test(\"Schema contains paths\", function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('paths');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/openapi.json",
          "host": ["{{baseUrl}}"],
          "path": ["openapi.json"]
        }
      }
    },
    {
      "name": "Docs Page",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains HTML content\", function () {",
              "    pm.expect(pm.response.text()).to.include('<html');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/docs",
          "host": ["{{baseUrl}}"],
          "path": ["docs"]
        }
      }
    }
  ]
}
